# Grafana
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin

# YOLO11 App
# 0 = first USB webcam, /app/videos/your_video.mp4 = video file
VIDEO_SOURCE=0
# auto = detect GPU automatically, cpu = force CPU, 0 = first GPU
DEVICE=auto
WEB_PORT=5000
